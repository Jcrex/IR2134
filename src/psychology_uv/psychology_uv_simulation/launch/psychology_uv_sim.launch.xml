<?xml version="1.0" ?>
<launch>
  <arg name="use_sim_time" default="true" />
  <arg name="failover_mode" default="false" />
  <arg name="use_tpe" default="false" />
  <arg name="ignition_version" default="6" />

  <!-- Common launch -->
  <include
	  file="$(find-pkg-share psychology_uv_config)/launch/psychology_uv_sim.launch.xml"
    >
    <arg name="use_sim_time" value="$(var use_sim_time)" />
    <arg name="failover_mode" value="$(var failover_mode)" />
    <arg name="use_tpe" value="$(var use_tpe)" />
  </include>

  <!-- Simulation launch -->
  <include
        file="$(find-pkg-share psychology_uv_simulation)/launch/simulation.launch.xml"
    >
    <arg name="map_name" value="psychology" />
    <arg name="ignition_version" value="$(var ignition_version)" />
  </include>
</launch>
